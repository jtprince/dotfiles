#!/usr/bin/env python3
import argparse
import gzip
from pathlib import Path

parser = argparse.ArgumentParser(
    usage="gzip-many [-k] <file> ...",
    description="Compress one or more files with gzip.",
)
parser.add_argument("files", nargs="+")
parser.add_argument("-k", "--keep", action="store_true", help="keep the originals")
args = parser.parse_args()

for path in map(Path, args.files):
    Path(str(path) + ".gz").write_bytes(gzip.compress(path.read_bytes(), compresslevel=6))
    if not args.keep:
        path.unlink()
