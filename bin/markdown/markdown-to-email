#!/usr/bin/env python

"""Convert markdown to Gmail-friendly HTML by inlining all CSS.

Gmail strips <style> blocks on paste, so blockquotes, code, tables etc. lose
their styling. This script runs pandoc (with the GitHub.html5 template) then
pipes the output through premailer, which inlines all CSS rules as style=""
attributes on each element. The result pastes into Gmail with full formatting.

Usage:
  markdown-to-email file.md              # produces file.email.html
  markdown-to-email file.md --open       # open in browser after conversion
  markdown-to-email file.md --dry        # show pandoc command, don't run
"""

from pathlib import Path
import argparse
import logging
import subprocess
import sys

try:
    import premailer
except ImportError:
    print("Error: premailer is not installed. Run: pip install premailer", file=sys.stderr)
    sys.exit(1)

PANDOC_CMD = "pandoc"
DEFAULT_SUFFIX = ".email.html"

# Suppress noisy cssutils warnings from premailer (vendor-prefixed properties etc.)
logging.getLogger("cssutils").setLevel(logging.CRITICAL)
logging.getLogger("CSSUTILS").setLevel(logging.CRITICAL)

parser = argparse.ArgumentParser(
    description="Convert markdown to Gmail-friendly HTML with inlined CSS"
)
parser.add_argument("markdown_files", nargs="+", type=Path, help="markdown file(s) to convert")
parser.add_argument("--suffix", default=DEFAULT_SUFFIX, help="output file suffix (default: .email.html)")
parser.add_argument("--open", action="store_true", help="open output in browser after conversion")
parser.add_argument("--dry", action="store_true", help="show pandoc command without running")
args = parser.parse_args()

pandoc_options = [
    "-fmarkdown+implicit_figures+smart",
    "--standalone",
    "--to", "html5",
    "--template", "GitHub.html5",
]

for path in args.markdown_files:
    outpath = path.with_suffix("").with_suffix("") if path.suffix == ".md" else path
    outpath = path.parent / (path.stem + args.suffix)

    cmd = [PANDOC_CMD, str(path), *pandoc_options]

    if args.dry:
        print(" ".join(cmd), "| premailer --stdin >", outpath)
        continue

    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        print(f"pandoc error for {path}:\n{result.stderr}", file=sys.stderr)
        sys.exit(result.returncode)

    inlined = premailer.transform(
        result.stdout,
        remove_classes=False,
        keep_style_tags=False,
        strip_important=False,
    )

    outpath.write_text(inlined, encoding="utf-8")
    print(outpath)

    if args.open:
        subprocess.run(["open", str(outpath)])
