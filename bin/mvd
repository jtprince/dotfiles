#!/usr/bin/env python
"""mvd — move the most-recently-modified file(s) from a source directory.

Usage:
    mvd <dest>              move the latest file to <dest>
    mvd <count> <dest>      move the latest <count> files to <dest>
    mvd -l                  list files without moving
    mvd -d <dir> <dest>     use <dir> instead of ~/Downloads
    mvd -t <dest>           use /tmp as source
    mvd -s <dest>           use ~/screenshots as source
"""

import argparse
import shutil
import sys
from pathlib import Path

SOURCE_DIR = Path.home() / "Downloads"

# Subdirectories within SOURCE_DIR to skip when scanning for files
IGNORE_SUBDIRS = {
    SOURCE_DIR / "screenshots",
    SOURCE_DIR / "old",
}


def latest_files(n: int, directory: Path) -> list[Path]:
    files = [p for p in directory.iterdir() if p.is_file() and p not in IGNORE_SUBDIRS]
    return sorted(files, key=lambda p: p.stat().st_mtime)[-n:]


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Move the latest downloaded file(s) to a destination.",
        usage="mvd [-l] [-d DIR | -t | -s] [COUNT] <dest>",
    )
    parser.add_argument("args", nargs="*", help="[COUNT] <dest>")
    parser.add_argument(
        "-l", "--list", action="store_true", help="list files, don't move"
    )
    parser.add_argument("-d", "--dir", metavar="DIR", help="source directory")
    parser.add_argument("-t", "--tmp", action="store_true", help="use /tmp as source")
    parser.add_argument(
        "-s", "--screenshots", action="store_true", help="use ~/screenshots as source"
    )

    opts = parser.parse_args()

    if opts.tmp:
        source = Path("/tmp")
    elif opts.screenshots:
        source = Path.home() / "screenshots"
    elif opts.dir:
        source = Path(opts.dir).expanduser()
    else:
        source = SOURCE_DIR

    if not opts.list and not opts.args:
        parser.print_help()
        sys.exit(1)

    count, dest = 1, None
    if len(opts.args) == 2:
        count, dest = int(opts.args[0]), Path(opts.args[1])
    elif opts.args:
        dest = Path(opts.args[0])

    if dest and count > 1 and not dest.is_dir():
        sys.exit("error: destination must be a directory when moving multiple files")

    files = latest_files(count, source)
    if not files:
        sys.exit(f"error: no files found in {source}")
    if any(".crdownload" in f.suffix for f in files):
        sys.exit("error: file is still downloading (.crdownload)")

    if opts.list:
        for f in files:
            print(f)
        return

    for f in files:
        shutil.move(str(f), dest)

    names = ", ".join(f.name for f in files)
    suffix = f" ---> {dest}" if str(dest) != "." else ""
    print(f"moved: {names}{suffix}")


if __name__ == "__main__":
    main()
