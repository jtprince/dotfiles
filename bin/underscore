#!/usr/bin/env python3
import argparse
import re
from pathlib import Path

parser = argparse.ArgumentParser(description="Replace spaces with underscores in filenames.")
parser.add_argument("files", nargs="+", type=Path)
parser.add_argument("-c", "--close-gaps", action="store_true", help="__ => _, _-_ => -")
args = parser.parse_args()

for path in args.files:
    name = path.name.replace(" ", "_")
    if args.close_gaps:
        name = re.sub(r"_+", "_", name).replace("_-_", "-")
    dest = path.with_name(name)
    if dest != path:
        path.rename(dest)
        print(f"renaming: {path} ==> {dest}")
    else:
        print(f"no spaces: {path}")
