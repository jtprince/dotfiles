#!/usr/bin/env python
"""
dotfiles-configure — idempotent symlink manager for macOS and Linux (Arch/Manjaro).

Detects the current platform and creates the appropriate set of symlinks from
this dotfiles repo into $HOME and $HOME/.config.

Usage:
    dotfiles-configure              # apply links for current platform
    dotfiles-configure --dry        # preview without changing anything
    dotfiles-configure --clean-broken  # remove dangling symlinks in ~/.config

Linux-only flags (ignored on macOS):
    -r/--resolution {4k,hd,mid}     # X11 resolution profile
    -d/--display-server {x11,wayland}
"""

from __future__ import annotations

import argparse
import platform
import shutil
from dataclasses import dataclass
from pathlib import Path

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------

HOME = Path.home()
REPO_ROOT = Path(__file__).resolve().parent.parent
REPO_CONFIG = (REPO_ROOT / "config").resolve()
HOME_CONFIG = HOME / ".config"
DOT_LOCAL = HOME / ".local"
CLOUD_ENV = HOME / "Dropbox" / "env"

IS_MAC = platform.system() == "Darwin"
IS_LINUX = platform.system() == "Linux"

CURRENT_RESOLUTION_MODE = HOME_CONFIG / "current-resolution-mode"

# ---------------------------------------------------------------------------
# Data model
# ---------------------------------------------------------------------------


@dataclass(frozen=True)
class Symlink:
    destination: Path
    link: Path


# ---------------------------------------------------------------------------
# Config entries — symlinked into ~/.config/<name>
# ---------------------------------------------------------------------------

CONFIG_GENERAL = [
    "alacritty",
    "cheat",
    "cursor-agent",
    "git",
    "ipython",
    "kitty",
    "nvim",
    "sheldon",
    "starship.toml",
    "uv",
    "zsh",
]

CONFIG_MAC = [
    "amethyst",
    "karabiner",
    "osascript",
]

CONFIG_LINUX = [
    "Xresources.d",
    "avizo",
    "blockify",
    "conky",
    "dunst",
    "feh",
    "flake8",
    "fontconfig",
    "goofys",
    "gtk-3.0",
    "imv",
    "isort.cfg",
    "latex",
    "mako",
    "mimeapps.list",
    "mpv",
    "mypy",
    "ncmpcpp",
    "ncspot",
    "npmrc",
    "pipewire",
    "pulse",
    "pulseaudio-ctl",
    "pylintrc",
    "ranger",
    "spotify-flags.conf",
    "sway",
    "texlive",
    "tofi",
    "waybar",
    "xava",
    "xmodmap",
]

# ---------------------------------------------------------------------------
# Home dotfiles — symlinked as ~/.<name>
# ---------------------------------------------------------------------------

HOME_DOTFILES_LINUX = [
    "xprofile",
    "xinitrc",
    "pryrc",
    "irbrc",
    "gemrc",
    "profile",
    "gtkrc-2.0",
]

# ---------------------------------------------------------------------------
# Explicit symlinks (destination -> link)
# ---------------------------------------------------------------------------

EXPLICIT_GENERAL: list[Symlink] = [
    Symlink(REPO_ROOT / "bin", link=HOME / "bin"),
    Symlink(REPO_CONFIG / "zsh/dot-zshenv", link=HOME / ".zshenv"),
    Symlink(REPO_CONFIG / "zsh/dot-zshrc", link=HOME / ".zshrc"),
    Symlink(REPO_CONFIG / "zsh/dot-zprofile", link=HOME / ".zprofile"),
    Symlink(REPO_CONFIG / "pandoc/data_dir", link=DOT_LOCAL / "share/pandoc"),
]

EXPLICIT_MAC: list[Symlink] = [
    Symlink(REPO_CONFIG / "hammerspoon", link=HOME / ".hammerspoon"),
]

EXPLICIT_LINUX: list[Symlink] = [
    Symlink(CLOUD_ENV / "gpg/dot-gnupg", link=HOME / ".gnupg"),
    Symlink(
        REPO_CONFIG / "mimeapps.list",
        link=DOT_LOCAL / "share/applications/mimeapps.list",
    ),
    Symlink(
        REPO_CONFIG / "applications/google-chrome-wayland-newwindow.desktop",
        link=DOT_LOCAL / "share/applications/google-chrome.desktop",
    ),
]

# ---------------------------------------------------------------------------
# Directories to ensure exist
# ---------------------------------------------------------------------------

ENSURE_DIRS_GENERAL: list[str] = []

ENSURE_DIRS_LINUX = [
    "npm",
    ".local/share/applications",
]

# ---------------------------------------------------------------------------
# Linux-only: resolution-dependent links
# ---------------------------------------------------------------------------


def _resolution_links(resolution: str) -> list[Symlink]:
    xresources = REPO_CONFIG / f"Xresources-{resolution}"
    return [
        Symlink(xresources, link=HOME / ".Xresources"),
        Symlink(xresources, link=HOME / ".Xdefaults"),
        Symlink(
            REPO_CONFIG / f"gtkrc-2.0-{resolution}",
            link=HOME / ".gtkrc-2.0-local",
        ),
        Symlink(
            REPO_CONFIG / f"x11-scale-factor-{resolution}",
            link=HOME_CONFIG / "x11-scale-factor",
        ),
    ]


# ---------------------------------------------------------------------------
# Linux-only: display-server-dependent links (Chrome/Electron flags)
# ---------------------------------------------------------------------------


def _chrome_flag_links(display_server: str) -> list[Symlink]:
    links: list[Symlink] = []
    for app in ["chrome", "electron"]:
        links.append(
            Symlink(
                REPO_CONFIG / "chrome" / f"{app}-flags.conf-{display_server}",
                link=HOME_CONFIG / f"{app}-flags.conf",
            )
        )
    links.append(
        Symlink(
            REPO_CONFIG / "chrome" / f"electron-flags.conf-{display_server}",
            link=HOME_CONFIG / "electron17-flags.conf",
        )
    )
    return links


# ---------------------------------------------------------------------------
# Symlinker
# ---------------------------------------------------------------------------


class Symlinker:
    def __init__(self, dry: bool = False):
        self.dry = dry

    def ensure_link(self, symlink: Symlink) -> None:
        if symlink.link.is_symlink():
            if symlink.link.resolve() == symlink.destination.resolve():
                print(f"  ✓ {symlink.link} -> {symlink.destination}")
                return
            print(f"  ✗ removing stale link: {symlink.link}")
            if not self.dry:
                symlink.link.unlink()
        elif symlink.link.exists():
            print(f"  ✗ removing real path: {symlink.link}")
            if not self.dry:
                if symlink.link.is_dir():
                    shutil.rmtree(symlink.link)
                else:
                    symlink.link.unlink()

        print(f"  → ln -s {symlink.destination} {symlink.link}")
        if not self.dry:
            symlink.link.symlink_to(symlink.destination)

    def ensure_links(self, symlinks: list[Symlink]) -> None:
        for s in symlinks:
            self.ensure_link(s)

    def link_into_config(self, names: list[str]) -> None:
        for name in names:
            self.ensure_link(Symlink(REPO_CONFIG / name, link=HOME_CONFIG / name))

    def link_into_home(self, names: list[str]) -> None:
        for name in names:
            self.ensure_link(Symlink(REPO_CONFIG / name, link=HOME / f".{name}"))

    def ensure_dirs(self, dirs: list[str]) -> None:
        for name in dirs:
            path = HOME / name
            print(f"  mkdir -p {path}")
            if not self.dry:
                path.mkdir(parents=True, exist_ok=True)


# ---------------------------------------------------------------------------
# Broken-link cleanup
# ---------------------------------------------------------------------------


def clean_broken_symlinks(dry: bool = False) -> None:
    """Remove dangling symlinks in ~/.config."""
    print("\nCleaning broken symlinks in ~/.config …")
    found = False
    for child in sorted(HOME_CONFIG.iterdir()):
        if child.is_symlink() and not child.resolve().exists():
            found = True
            print(f"  ✗ broken: {child} -> {child.readlink()}")
            if not dry:
                child.unlink()
    if not found:
        print("  (none found)")


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

RESOLUTIONS = ["4k", "hd", "mid"]


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Idempotent dotfile symlink manager (macOS + Linux).",
    )
    parser.add_argument("--dry", action="store_true", help="preview without changes")
    parser.add_argument(
        "--clean-broken",
        action="store_true",
        help="remove dangling symlinks in ~/.config",
    )

    if IS_LINUX:
        parser.add_argument(
            "-r",
            "--resolution",
            choices=RESOLUTIONS,
            help="X11 resolution profile (default: read from previous run)",
        )
        parser.add_argument(
            "-d",
            "--display-server",
            choices=["x11", "wayland"],
            default="wayland",
            help="display server (default: wayland)",
        )

    return parser


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    linker = Symlinker(dry=args.dry)
    prefix = "[DRY RUN] " if args.dry else ""

    if args.clean_broken:
        clean_broken_symlinks(dry=args.dry)
        return

    # -- Directories --------------------------------------------------------
    all_dirs = list(ENSURE_DIRS_GENERAL)
    if IS_LINUX:
        all_dirs += ENSURE_DIRS_LINUX
    if all_dirs:
        print(f"{prefix}Ensuring directories …")
        linker.ensure_dirs(all_dirs)

    # -- ~/.config links ----------------------------------------------------
    config_names = list(CONFIG_GENERAL)
    if IS_MAC:
        config_names += CONFIG_MAC
    elif IS_LINUX:
        config_names += CONFIG_LINUX

    print(f"\n{prefix}Linking into ~/.config …")
    linker.link_into_config(config_names)

    # -- ~/.<name> home dotfiles --------------------------------------------
    if IS_LINUX and HOME_DOTFILES_LINUX:
        print(f"\n{prefix}Linking home dotfiles …")
        linker.link_into_home(HOME_DOTFILES_LINUX)

    # -- Explicit symlinks --------------------------------------------------
    explicit = list(EXPLICIT_GENERAL)
    if IS_MAC:
        explicit += EXPLICIT_MAC
    elif IS_LINUX:
        explicit += EXPLICIT_LINUX

    print(f"\n{prefix}Explicit symlinks …")
    linker.ensure_links(explicit)

    # -- Linux-only: resolution & display-server links ----------------------
    if IS_LINUX:
        resolution = getattr(args, "resolution", None)
        if resolution is None:
            try:
                resolution = CURRENT_RESOLUTION_MODE.read_text().strip()
                print(f"\nUsing saved resolution: {resolution}")
            except FileNotFoundError:
                print("\nNo resolution specified and none saved — skipping.")
                resolution = None

        if resolution:
            print(f"\n{prefix}Resolution-dependent links ({resolution}) …")
            linker.ensure_links(_resolution_links(resolution))
            if not args.dry:
                CURRENT_RESOLUTION_MODE.write_text(resolution)

        display_server = getattr(args, "display_server", "wayland")
        print(f"\n{prefix}Display-server links ({display_server}) …")
        linker.ensure_links(_chrome_flag_links(display_server))

    print(f"\n{prefix}Done.")


if __name__ == "__main__":
    main()
