#!/usr/bin/env python
"""
dotfiles-configure — idempotent symlink manager for macOS and Linux (Arch/Manjaro).

Detects the current platform and creates the appropriate set of symlinks from
this dotfiles repo into $HOME and $HOME/.config.

Usage:
    dotfiles-configure              # apply links for current platform
    dotfiles-configure --dry        # preview without changing anything
    dotfiles-configure --clean-broken  # remove dangling symlinks in ~/.config
"""

from __future__ import annotations

import argparse
import platform
import shutil
import subprocess
from dataclasses import dataclass
from pathlib import Path

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------

HOME = Path.home()
REPO_ROOT = Path(__file__).resolve().parent.parent
REPO_CONFIG = (REPO_ROOT / "config").resolve()
HOME_CONFIG = HOME / ".config"
DOT_LOCAL = HOME / ".local"
CLOUD_ENV = HOME / "Dropbox" / "env"

IS_MAC = platform.system() == "Darwin"
IS_LINUX = platform.system() == "Linux"

# ---------------------------------------------------------------------------
# Data model
# ---------------------------------------------------------------------------


@dataclass(frozen=True)
class Symlink:
    destination: Path
    link: Path
    backup: Path | None = None


# ---------------------------------------------------------------------------
# Config entries — symlinked into ~/.config/<name>
# ---------------------------------------------------------------------------

CONFIG_GENERAL = [
    "cheat",
    "cmux",
    "cursor-agent",
    "ghostty",
    "git",
    "ipython",
    "kitty",
    "nvim",
    "sheldon",
    "spotify-player",
    "starship.toml",
    "uv",
    "zsh",
    "mpv",
]

CONFIG_MAC = [
    "mac/amethyst",
    "mac/karabiner",
    "mac/osascript",
]

CONFIG_LINUX = [
    # "linux/Xresources.d",
    # "linux/avizo",
    # "linux/dunst",
    "linux/feh",
    # "linux/fontconfig",
    # "linux/goofys",
    # "linux/gtk-3.0",
    # "linux/imv",
    "linux/latex",
    "linux/mako",
    # "linux/mimeapps.list",
    # "linux/mypy",
    # "linux/npmrc",
    # "linux/pipewire",
    # "linux/pulse",
    # "linux/pulseaudio-ctl",
    "linux/ranger",
    # "linux/spotify-flags.conf",
    # "linux/sway",
    # "linux/texlive",
    # "linux/tofi",
    # "linux/waybar",
    # "linux/xmodmap",
]

# ---------------------------------------------------------------------------
# Home dotfiles — symlinked as ~/.<name>
# ---------------------------------------------------------------------------

HOME_DOTFILES_LINUX = [
    # "linux/xprofile",
    # "linux/xinitrc",
    # "linux/gtkrc-2.0",
]

# ---------------------------------------------------------------------------
# Explicit symlinks (destination -> link)
# ---------------------------------------------------------------------------

EXPLICIT_GENERAL: list[Symlink] = [
    Symlink(REPO_ROOT / "bin", link=HOME / "bin"),
    Symlink(REPO_CONFIG / "zsh/dot-zshenv", link=HOME / ".zshenv"),
    Symlink(REPO_CONFIG / "zsh/dot-zshrc", link=HOME / ".zshrc"),
    Symlink(REPO_CONFIG / "zsh/dot-zprofile", link=HOME / ".zprofile"),
    Symlink(REPO_CONFIG / "pandoc/data_dir", link=DOT_LOCAL / "share/pandoc"),
    Symlink(
        REPO_CONFIG / "agent/skills/link-check",
        link=HOME / ".claude/skills/link-check",
    ),
    Symlink(
        REPO_CONFIG / "agent/skills/link-check",
        link=HOME / ".codex/skills/link-check",
    ),
    Symlink(REPO_CONFIG / "claude/hooks", link=HOME / ".claude/hooks"),
    Symlink(REPO_CONFIG / "claude/CLAUDE.md", link=HOME / ".claude/CLAUDE.md"),
    Symlink(REPO_CONFIG / "codex/AGENTS.md", link=HOME / ".codex/AGENTS.md"),
    Symlink(
        REPO_CONFIG / "codex/config.toml",
        link=HOME / ".codex/config.toml",
        backup=HOME / ".codex/backups/dotfiles-migration/config.toml",
    ),
    Symlink(REPO_CONFIG / "codex/hooks.json", link=HOME / ".codex/hooks.json"),
    Symlink(
        REPO_CONFIG / "codex/rules/default.rules",
        link=HOME / ".codex/rules/default.rules",
        backup=HOME / ".codex/backups/dotfiles-migration/default.rules",
    ),
]

EXPLICIT_MAC: list[Symlink] = [
    Symlink(REPO_CONFIG / "mac/hammerspoon", link=HOME / ".hammerspoon"),
    Symlink(
        REPO_CONFIG / "cavemem/settings.json", link=HOME / ".cavemem/settings.json"
    ),
    Symlink(REPO_CONFIG / "claude/settings.json", link=HOME / ".claude/settings.json"),
]

EXPLICIT_LINUX: list[Symlink] = [
    Symlink(CLOUD_ENV / "gpg/dot-gnupg", link=HOME / ".gnupg"),
    Symlink(
        REPO_CONFIG / "linux/mimeapps.list",
        link=DOT_LOCAL / "share/applications/mimeapps.list",
    ),
]

# ---------------------------------------------------------------------------
# Directories to ensure exist
# ---------------------------------------------------------------------------

ENSURE_DIRS_GENERAL: list[str] = []

ENSURE_DIRS_LINUX = [
    "npm",
    ".local/share/applications",
]

# ---------------------------------------------------------------------------
# Git filters — strip ephemeral keys (e.g. Claude's `model` picker) from
# tracked config before they hit git's object store, without touching the
# live file on disk. See config/claude/settings.json + .gitattributes.
# ---------------------------------------------------------------------------

GIT_FILTERS: dict[str, str] = {
    "claude-settings.clean": 'jq "del(.model)"',
    "codex-config.clean": "python3 config/codex/clean-config.py",
    "codex-config.required": "true",
}


def configure_git_filters(dry: bool = False) -> None:
    print("\nConfiguring git filters …")
    for key, value in GIT_FILTERS.items():
        print(f"  git config filter.{key} '{value}'")
        if not dry:
            subprocess.run(
                ["git", "config", f"filter.{key}", value],
                cwd=REPO_ROOT,
                check=True,
            )


# ---------------------------------------------------------------------------
# Symlinker
# ---------------------------------------------------------------------------


class Symlinker:
    def __init__(self, dry: bool = False):
        self.dry = dry

    def ensure_link(self, symlink: Symlink) -> None:
        if symlink.link.is_symlink():
            if symlink.link.resolve() == symlink.destination.resolve():
                print(f"  ✓ {symlink.link} -> {symlink.destination}")
                return
            print(f"  ✗ removing stale link: {symlink.link}")
            if not self.dry:
                symlink.link.unlink()
        elif symlink.link.exists():
            if symlink.backup is not None and not symlink.backup.exists():
                print(f"  ↳ backup {symlink.link} -> {symlink.backup}")
                if not self.dry:
                    symlink.backup.parent.mkdir(parents=True, exist_ok=True)
                    shutil.copy2(symlink.link, symlink.backup)
            print(f"  ✗ removing real path: {symlink.link}")
            if not self.dry:
                if symlink.link.is_dir():
                    shutil.rmtree(symlink.link)
                else:
                    symlink.link.unlink()

        print(f"  → ln -s {symlink.destination} {symlink.link}")
        if not self.dry:
            symlink.link.parent.mkdir(parents=True, exist_ok=True)
            symlink.link.symlink_to(symlink.destination)

    def ensure_links(self, symlinks: list[Symlink]) -> None:
        for s in symlinks:
            self.ensure_link(s)

    def link_into_config(self, names: list[str]) -> None:
        for name in names:
            link_name = Path(name).name
            self.ensure_link(Symlink(REPO_CONFIG / name, link=HOME_CONFIG / link_name))

    def link_into_home(self, names: list[str]) -> None:
        for name in names:
            link_name = Path(name).name
            self.ensure_link(Symlink(REPO_CONFIG / name, link=HOME / f".{link_name}"))

    def ensure_dirs(self, dirs: list[str]) -> None:
        for name in dirs:
            path = HOME / name
            print(f"  mkdir -p {path}")
            if not self.dry:
                path.mkdir(parents=True, exist_ok=True)


# ---------------------------------------------------------------------------
# Broken-link cleanup
# ---------------------------------------------------------------------------


def clean_broken_symlinks(dry: bool = False) -> None:
    """Remove dangling symlinks in ~/.config."""
    print("\nCleaning broken symlinks in ~/.config …")
    found = False
    for child in sorted(HOME_CONFIG.iterdir()):
        if child.is_symlink() and not child.resolve().exists():
            found = True
            print(f"  ✗ broken: {child} -> {child.readlink()}")
            if not dry:
                child.unlink()
    if not found:
        print("  (none found)")


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Idempotent dotfile symlink manager (macOS + Linux).",
    )
    parser.add_argument("--dry", action="store_true", help="preview without changes")
    parser.add_argument(
        "--clean-broken",
        action="store_true",
        help="remove dangling symlinks in ~/.config",
    )

    return parser


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    linker = Symlinker(dry=args.dry)
    prefix = "[DRY RUN] " if args.dry else ""

    if args.clean_broken:
        clean_broken_symlinks(dry=args.dry)
        return

    configure_git_filters(dry=args.dry)

    # -- Directories --------------------------------------------------------
    all_dirs = list(ENSURE_DIRS_GENERAL)
    if IS_LINUX:
        all_dirs += ENSURE_DIRS_LINUX
    if all_dirs:
        print(f"{prefix}Ensuring directories …")
        linker.ensure_dirs(all_dirs)

    # -- ~/.config links ----------------------------------------------------
    config_names = list(CONFIG_GENERAL)
    if IS_MAC:
        config_names += CONFIG_MAC
    elif IS_LINUX:
        config_names += CONFIG_LINUX

    print(f"\n{prefix}Linking into ~/.config …")
    linker.link_into_config(config_names)

    # -- ~/.<name> home dotfiles --------------------------------------------
    if IS_LINUX and HOME_DOTFILES_LINUX:
        print(f"\n{prefix}Linking home dotfiles …")
        linker.link_into_home(HOME_DOTFILES_LINUX)

    # -- Explicit symlinks --------------------------------------------------
    explicit = list(EXPLICIT_GENERAL)
    if IS_MAC:
        explicit += EXPLICIT_MAC
    elif IS_LINUX:
        explicit += EXPLICIT_LINUX

    print(f"\n{prefix}Explicit symlinks …")
    linker.ensure_links(explicit)


if __name__ == "__main__":
    main()
