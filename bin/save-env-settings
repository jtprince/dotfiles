#!/usr/bin/env python3
"""Save directories as password-protected 7z archives to Dropbox."""

import argparse
import os
import subprocess
from contextlib import contextmanager
from pathlib import Path

home = Path.home()
SAVE_TO = home / "Dropbox/env/passwds_logins/"
DEFAULTS = [home / ".ssh"]


@contextmanager
def cd(path: Path):
    prev = os.getcwd()
    os.chdir(path)
    try:
        yield
    finally:
        os.chdir(prev)


def save_path(path: Path, save_to: Path) -> None:
    name = path.name
    zipname = ("dot-" + name[1:]) if name.startswith(".") else name
    secure_name = zipname + ".secure.7z"

    print(f"Saving {path} ...")
    with cd(path.parent):
        result = subprocess.run(["7z", "a", "-p", secure_name, name])
        if result.returncode != 0:
            raise RuntimeError(f"7z failed for {path}")
        dest = save_to / secure_name
        print(f"Moving to: {dest}")
        Path(secure_name).rename(dest)


parser = argparse.ArgumentParser(description="Save directories as password-protected 7z archives to Dropbox.")
parser.add_argument("dirs", nargs="*", metavar="dir", help=f"directories to save (default: {' '.join(str(d) for d in DEFAULTS)})")
parser.add_argument("--save-to", type=Path, default=SAVE_TO, metavar="DIR", help=f"destination directory (default: {SAVE_TO})")
args = parser.parse_args()

paths = [Path(d) for d in args.dirs] if args.dirs else DEFAULTS

for path in paths:
    save_path(path, args.save_to)
