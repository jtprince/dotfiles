#!/usr/bin/env python3
import platform
import shutil
import subprocess
import sys


def read_clipboard() -> str:
    os = platform.system()
    if os == "Darwin":
        return subprocess.check_output(["pbpaste"], text=True).strip()
    elif os == "Linux":
        if shutil.which("wl-paste"):
            return subprocess.check_output(["wl-paste", "--no-newline"], text=True).strip()
        elif shutil.which("xclip"):
            return subprocess.check_output(["xclip", "-selection", "clipboard", "-o"], text=True).strip()
        else:
            sys.exit("error: need wl-paste (Wayland) or xclip (X11) installed")
    else:
        sys.exit(f"error: unsupported OS: {os}")


def open_url(url: str) -> None:
    if platform.system() == "Darwin":
        subprocess.run(["open", url])
    else:
        subprocess.run(["xdg-open", url])


url = read_clipboard()

if not url.startswith("http"):
    sys.exit(f"error: clipboard does not contain a URL: {url!r}")

print(f"opening: {url}")
open_url(url)
