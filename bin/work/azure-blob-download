#!/usr/bin/env python3
"""Download files from Azure Blob Storage.

Examples:

    # direct az:// URL mode
    uv run azure-blob-download \
        --storage-account miscdevncus01 \
        "az://user-junk-365d-delete/ckrettle/datamoat/enamine-release/output/test-tiny/final_spectra.jsonl"

    # explicit container/prefix mode
    uv run azure-blob-download \
        --storage-account miscdevncus01 \
        --container user-junk-365d-delete \
        --download-dir ckrettle/datamoat/enamine-release/output/test-tiny \
        final_spectra.jsonl

    # multiple files in container/prefix mode
    uv run azure-blob-download \
        --storage-account miscdevncus01 \
        --container user-junk-365d-delete \
        --download-dir ckrettle/datamoat/enamine-release/output/test-tiny \
        final_spectra.jsonl \
        other_file.jsonl

    # recursive download from an az:// prefix
    uv run azure-blob-download \
        --storage-account miscdevncus01 \
        --recursive \
        "az://user-junk-365d-delete/ckrettle/datamoat/enamine-release/output/test-tiny/"

    # recursive download from container/prefix mode
    uv run azure-blob-download \
        --storage-account miscdevncus01 \
        --container user-junk-365d-delete \
        --download-dir ckrettle/datamoat/enamine-release/output/test-tiny \
        --recursive

    # verify active subscription first
    uv run azure-blob-download \
        --subscription sub-enveda-data-dev-01 \
        --storage-account miscdevncus01 \
        "az://user-junk-365d-delete/ckrettle/datamoat/enamine-release/output/test-tiny/final_spectra.jsonl"

    # just list visible storage accounts
    uv run azure-blob-download --list-accounts
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
import threading
import time
from concurrent.futures import ThreadPoolExecutor, as_completed
from pathlib import Path
from typing import Iterable, List, Tuple, TypeVar
from urllib.parse import urlparse

T = TypeVar("T")


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Download files from Azure Blob Storage.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument(
        "-s",
        "--subscription",
        help="Expected Azure subscription name or id (checked via `az account show`).",
    )
    parser.add_argument(
        "-a",
        "--storage-account",
        help="Azure storage account name.",
    )
    parser.add_argument(
        "-c",
        "--container",
        help="Blob container name. Omit when using az:// URLs.",
    )
    parser.add_argument(
        "-d",
        "--download-dir",
        help="Remote path prefix in the container. Used in container/prefix mode.",
    )
    parser.add_argument(
        "-o",
        "--output-dir",
        type=Path,
        default=Path("."),
        help="Local output directory (default: current directory).",
    )
    parser.add_argument(
        "-r",
        "--recursive",
        action="store_true",
        help="Download recursively from the given prefix.",
    )
    parser.add_argument(
        "--batch-size",
        type=int,
        default=250,
        help="Number of files to process per batch for progress reporting (default: 250).",
    )
    parser.add_argument(
        "--workers",
        type=int,
        default=16,
        metavar="N",
        help="Concurrent download workers for --recursive (default: 16). Use 1 for sequential.",
    )
    parser.add_argument(
        "--list-accounts",
        action="store_true",
        help="List visible storage accounts and exit.",
    )
    parser.add_argument(
        "paths",
        nargs="*",
        help=(
            "Either az:// URLs, or remote paths relative to --download-dir in "
            "container/prefix mode. When --recursive is used with container/prefix "
            "mode, positional paths are optional."
        ),
    )
    return parser.parse_args()


def run_az(cmd: List[str], capture_output: bool = False) -> subprocess.CompletedProcess:
    return subprocess.run(
        ["az"] + cmd,
        check=True,
        capture_output=capture_output,
        text=True,
    )


def get_active_subscription() -> dict:
    try:
        proc = run_az(["account", "show", "-o", "json"], capture_output=True)
    except FileNotFoundError:
        print("ERROR: `az` CLI not found in PATH.", file=sys.stderr)
        sys.exit(2)
    except subprocess.CalledProcessError as exc:
        print("ERROR: failed to run `az account show`.", file=sys.stderr)
        if exc.stderr:
            print(exc.stderr.strip(), file=sys.stderr)
        sys.exit(2)

    try:
        data = json.loads(proc.stdout)
    except json.JSONDecodeError:
        print("ERROR: could not parse output from `az account show`.", file=sys.stderr)
        sys.exit(2)

    return {
        "name": str(data.get("name", "")),
        "id": str(data.get("id", "")),
    }


def verify_subscription(expected: str) -> None:
    active = get_active_subscription()
    if expected not in {active["name"], active["id"]}:
        print(
            "ERROR: active Azure subscription does not match.\n"
            "  expected: {expected}\n"
            "  active name: {name}\n"
            "  active id:   {id}".format(
                expected=expected,
                name=active["name"],
                id=active["id"],
            ),
            file=sys.stderr,
        )
        sys.exit(2)


def list_accounts() -> None:
    try:
        proc = run_az(["storage", "account", "list", "-o", "json"], capture_output=True)
    except subprocess.CalledProcessError as exc:
        print("ERROR: failed to list storage accounts.", file=sys.stderr)
        if exc.stderr:
            print(exc.stderr.strip(), file=sys.stderr)
        sys.exit(2)

    accounts = json.loads(proc.stdout)
    for account in accounts:
        print(account["name"])


def parse_az_url(url: str) -> Tuple[str, str]:
    parsed = urlparse(url)
    if parsed.scheme != "az":
        raise ValueError("expected az:// URL, got: {url}".format(url=url))
    container = parsed.netloc
    blob_path = parsed.path.lstrip("/")
    if not container:
        raise ValueError("missing container in URL: {url}".format(url=url))
    return container, blob_path


def is_az_url(value: str) -> bool:
    return value.startswith("az://")


def join_blob_path(prefix: str | None, suffix: str | None) -> str:
    parts = []
    if prefix:
        parts.append(prefix.strip("/"))
    if suffix:
        parts.append(suffix.strip("/"))
    return "/".join(part for part in parts if part)


def infer_local_path(
    blob_path: str, output_dir: Path, preserve_structure: bool
) -> Path:
    if preserve_structure:
        return output_dir / Path(blob_path)
    return output_dir / Path(blob_path).name


class DownloadError(Exception):
    """A blob failed to download after exhausting all retries."""


DEFAULT_RETRIES = 4


def get_blob_size(storage_account: str, container: str, blob_path: str) -> int | None:
    """Return the blob's Content-Length in bytes, or None if it can't be read.

    Used to decide whether a local file is already a complete copy so we can
    skip re-downloading it (idempotent resume). Best-effort: any failure just
    means "unknown", and the caller will re-download.
    """
    try:
        proc = run_az(
            [
                "storage",
                "blob",
                "show",
                "--account-name",
                storage_account,
                "--container-name",
                container,
                "--name",
                blob_path,
                "--auth-mode",
                "login",
                "--query",
                "properties.contentLength",
                "--output",
                "tsv",
            ],
            capture_output=True,
        )
    except subprocess.CalledProcessError:
        return None
    value = proc.stdout.strip()
    try:
        return int(value)
    except ValueError:
        return None


def local_is_complete(output_file: Path, expected_size: int | None) -> bool:
    """True when output_file already exists with exactly expected_size bytes.

    Conservative: if the expected size is unknown (None) we report incomplete
    so the caller downloads rather than trusting a possibly-partial file.
    """
    if expected_size is None:
        return False
    try:
        return output_file.is_file() and output_file.stat().st_size == expected_size
    except OSError:
        return False


def download_blob(
    *,
    storage_account: str,
    container: str,
    blob_path: str,
    output_file: Path,
    retries: int = DEFAULT_RETRIES,
) -> None:
    """Download a single blob, retrying transient failures with backoff.

    Raises DownloadError after exhausting retries instead of killing the
    process, so callers can keep the rest of a batch/pool going and aggregate
    failures at the end (a single flaky blob shouldn't abort a 150 GB pull).
    """
    output_file.parent.mkdir(parents=True, exist_ok=True)
    last_stderr = ""
    for attempt in range(1, retries + 1):
        try:
            run_az(
                [
                    "storage",
                    "blob",
                    "download",
                    "--account-name",
                    storage_account,
                    "--container-name",
                    container,
                    "--name",
                    blob_path,
                    "--file",
                    str(output_file),
                    "--auth-mode",
                    "login",
                    "--overwrite",
                    "true",
                    "--only-show-errors",
                    "--output",
                    "none",
                ]
            )
            return
        except subprocess.CalledProcessError as exc:
            last_stderr = (exc.stderr or "").strip()
            if attempt < retries:
                backoff = min(2 ** attempt, 30)
                print(
                    "  transient error on az://{c}/{b} "
                    "(attempt {a}/{r}); retrying in {s}s".format(
                        c=container, b=blob_path, a=attempt, r=retries, s=backoff
                    ),
                    file=sys.stderr,
                )
                time.sleep(backoff)
    raise DownloadError(
        "az://{c}/{b}: {e}".format(c=container, b=blob_path, e=last_stderr)
    )


def list_blobs_under_prefix(
    storage_account: str, container: str, prefix: str
) -> List[dict]:
    """List blobs under prefix as [{"name": str, "size": int | None}, ...]."""
    try:
        proc = run_az(
            [
                "storage",
                "blob",
                "list",
                "--account-name",
                storage_account,
                "--container-name",
                container,
                "--prefix",
                prefix,
                "--auth-mode",
                "login",
                "--output",
                "json",
                "--query",
                "[].{name:name, size:properties.contentLength}",
            ],
            capture_output=True,
        )
    except subprocess.CalledProcessError as exc:
        print(
            "ERROR: failed to list blobs under az://{container}/{prefix}".format(
                container=container,
                prefix=prefix,
            ),
            file=sys.stderr,
        )
        if exc.stderr:
            print(exc.stderr.strip(), file=sys.stderr)
        sys.exit(1)
    return json.loads(proc.stdout)


def download_recursive(
    *,
    storage_account: str,
    container: str,
    prefix: str,
    output_dir: Path,
    workers: int,
) -> None:
    output_dir.mkdir(parents=True, exist_ok=True)

    blobs = list_blobs_under_prefix(storage_account, container, prefix)

    # Blob storage has a flat namespace: Bruker .d/.m subfolders get uploaded
    # with a zero-byte placeholder blob literally named e.g. "8562.m/" in
    # addition to the real blobs under "8562.m/...". Downloading the
    # placeholder would try to materialize a file at a path where a
    # directory is needed, so skip anything that is itself a folder marker.
    real_blobs = [b for b in blobs if not b["name"].endswith("/")]
    markers = len(blobs) - len(real_blobs)
    if markers:
        print(f"Skipping {markers} folder-marker blob(s).")

    if not real_blobs:
        print("No blobs to download.")
        return

    stripped_prefix = prefix.strip("/")
    total = len(real_blobs)
    print(f"Downloading {total} file(s) ({workers} worker{'s' if workers != 1 else ''})")

    counts = {"downloaded": 0, "skipped": 0}
    failures: List[str] = []
    processed = 0
    lock = threading.Lock()

    def handle_one(blob: dict) -> Tuple[str, str]:
        blob_name = blob["name"]
        rel_path = (
            blob_name[len(stripped_prefix):].lstrip("/")
            if stripped_prefix
            else blob_name
        )
        output_file = output_dir / rel_path
        # Idempotent resume: a re-run over a partly-downloaded tree skips files
        # already present at their full size instead of re-fetching them.
        if local_is_complete(output_file, blob.get("size")):
            return "skipped", blob_name
        try:
            download_blob(
                storage_account=storage_account,
                container=container,
                blob_path=blob_name,
                output_file=output_file,
            )
        except DownloadError as exc:
            return "failed", str(exc)
        return "downloaded", blob_name

    with ThreadPoolExecutor(max_workers=workers) as pool:
        futures = {pool.submit(handle_one, b): b for b in real_blobs}
        for future in as_completed(futures):
            status, detail = future.result()
            with lock:
                processed += 1
                if status == "failed":
                    failures.append(detail)
                    print(f"[{processed}/{total}] ✗ {detail}", file=sys.stderr)
                else:
                    counts[status] += 1
                    label = "= (exists)" if status == "skipped" else "✓"
                    print(f"[{processed}/{total}] {label} az://{container}/{detail}")

    print(
        "Recursive done: {d} downloaded, {s} skipped, {f} failed.".format(
            d=counts["downloaded"], s=counts["skipped"], f=len(failures)
        )
    )
    if failures:
        print("Failures:", file=sys.stderr)
        for msg in failures:
            print(f"  {msg}", file=sys.stderr)
        sys.exit(1)


def chunked(items: List[T], size: int) -> Iterable[List[T]]:
    for i in range(0, len(items), size):
        yield items[i : i + size]


def resolve_inputs(args: argparse.Namespace) -> Tuple[str, List[Tuple[str, str]]]:
    if not args.storage_account:
        print("ERROR: --storage-account is required.", file=sys.stderr)
        sys.exit(2)

    if not args.paths and not args.recursive:
        print("ERROR: provide az:// paths or container/prefix inputs.", file=sys.stderr)
        sys.exit(2)

    has_az_urls = any(is_az_url(path) for path in args.paths)
    has_plain_paths = any(not is_az_url(path) for path in args.paths)

    if has_az_urls and has_plain_paths:
        print("ERROR: do not mix az:// URLs with plain remote paths.", file=sys.stderr)
        sys.exit(2)

    resolved: List[Tuple[str, str]] = []

    if has_az_urls:
        if args.container or args.download_dir:
            print(
                "ERROR: --container/--download-dir are not used with az:// URL mode.",
                file=sys.stderr,
            )
            sys.exit(2)
        for url in args.paths:
            container, blob_path = parse_az_url(url)
            resolved.append((container, blob_path))
        return args.storage_account, resolved

    if not args.container:
        print(
            "ERROR: --container is required in container/prefix mode.", file=sys.stderr
        )
        sys.exit(2)

    base_prefix = args.download_dir or ""

    if args.recursive and not args.paths:
        resolved.append((args.container, base_prefix))
        return args.storage_account, resolved

    if not args.paths:
        print("ERROR: no remote paths provided.", file=sys.stderr)
        sys.exit(2)

    for path in args.paths:
        blob_path = join_blob_path(base_prefix, path)
        resolved.append((args.container, blob_path))

    return args.storage_account, resolved


def main() -> None:
    args = parse_args()

    if args.list_accounts:
        list_accounts()
        return

    if args.batch_size < 1:
        print("ERROR: --batch-size must be >= 1", file=sys.stderr)
        sys.exit(2)

    if args.subscription:
        verify_subscription(args.subscription)

    storage_account, targets = resolve_inputs(args)
    args.output_dir.mkdir(parents=True, exist_ok=True)

    if args.recursive:
        if len(targets) != 1:
            print(
                "ERROR: recursive mode currently expects exactly one prefix target.",
                file=sys.stderr,
            )
            sys.exit(2)

        container, prefix = targets[0]
        local_dir_name = Path(prefix.rstrip("/")).name if prefix else container
        local_dir = args.output_dir / local_dir_name

        print(
            "Downloading recursively from az://{container}/{prefix} -> {local_dir}".format(
                container=container,
                prefix=prefix,
                local_dir=local_dir,
            )
        )
        download_recursive(
            storage_account=storage_account,
            container=container,
            prefix=prefix,
            output_dir=local_dir,
            workers=args.workers,
        )
        print("Done.")
        return

    total = len(targets)
    print("Downloading {total} file(s) from Azure Blob Storage".format(total=total))

    downloaded = 0
    skipped = 0
    failures: List[str] = []
    processed = 0
    for batch_num, batch in enumerate(chunked(targets, args.batch_size), start=1):
        print(
            "\nBatch {batch_num}: {count} file(s)".format(
                batch_num=batch_num, count=len(batch)
            )
        )
        for container, blob_path in batch:
            local_file = infer_local_path(
                blob_path=blob_path,
                output_dir=args.output_dir,
                preserve_structure=False,
            )
            processed += 1
            # Idempotent resume: only pay for a `blob show` size check when a
            # local file already exists; skip it when already complete.
            if local_file.is_file() and local_is_complete(
                local_file, get_blob_size(storage_account, container, blob_path)
            ):
                skipped += 1
                print(
                    "[{p}/{t}] = (exists) az://{c}/{b}".format(
                        p=processed, t=total, c=container, b=blob_path
                    )
                )
                continue
            try:
                download_blob(
                    storage_account=storage_account,
                    container=container,
                    blob_path=blob_path,
                    output_file=local_file,
                )
            except DownloadError as exc:
                failures.append(str(exc))
                print(f"[{processed}/{total}] ✗ {exc}", file=sys.stderr)
                continue
            downloaded += 1
            print(
                "[{p}/{t}] ✓ az://{c}/{b} -> {f}".format(
                    p=processed, t=total, c=container, b=blob_path, f=local_file
                )
            )

    print(
        "\nDone: {d} downloaded, {s} skipped, {f} failed.".format(
            d=downloaded, s=skipped, f=len(failures)
        )
    )
    if failures:
        print("Failures:", file=sys.stderr)
        for msg in failures:
            print(f"  {msg}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
