#!/usr/bin/env python
"""Upload local files to Azure Blob Storage.

Examples:

    # safest: let Python expand the glob, not the shell
    uv run azure-blob-upload \
        --subscription sub-enveda-data-dev-01 \
        --storage-account inferencedevncus01 \
        --container prism2 \
        --upload-dir input/batch01-ms1-context-only \
        --glob '~/projects/prism2-data-prepper/output/MSB*_MSB*.parquet'

    # explicit files still work
    uv run azure-blob-upload \
        --subscription sub-enveda-data-dev-01 \
        --storage-account inferencedevncus01 \
        --container prism2 \
        --upload-dir input/batch01-ms1-context-only \
        ~/projects/prism2-data-prepper/output/MSB104409_MSB104410.prism2input.parquet \
        ~/projects/prism2-data-prepper/output/MSB104401_MSB104402.prism2input.parquet
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
import threading
from concurrent.futures import ThreadPoolExecutor, as_completed
from glob import glob
from pathlib import Path

# NOTE: no --recursive/directory-tree upload today (files are flattened to
# basename in upload_blob()), so this can't create or choke on zero-byte
# Azure folder-marker blobs (trailing "/" names). If recursive upload is
# ever added here, filter those out the way azure-blob-download's
# download_recursive() does (skip names ending in "/") — that function's
# git history has the bug this guards against.


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Upload files to Azure Blob Storage.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument(
        "-s",
        "--subscription",
        required=True,
        help="Expected Azure subscription name or id (checked via `az account show`).",
    )
    parser.add_argument(
        "-a",
        "--storage-account",
        required=True,
        help="Azure storage account name",
    )
    parser.add_argument(
        "-c",
        "--container",
        required=True,
        help="Blob container name",
    )
    parser.add_argument(
        "-d",
        "--upload-dir",
        required=True,
        help="Remote path prefix in the container, e.g. input/batch01-ms1-context-only",
    )
    parser.add_argument(
        "--glob",
        dest="globs",
        action="append",
        default=[],
        help=(
            "Glob pattern to expand inside Python. Quote it so the shell does not expand it. "
            "May be provided multiple times."
        ),
    )
    parser.add_argument(
        "--workers",
        type=int,
        default=16,
        metavar="N",
        help="Concurrent upload workers (default: 16). Use 1 for sequential.",
    )
    parser.add_argument(
        "--skip-existing",
        action="store_true",
        help="Skip files already present in the target prefix (name-based, no content check).",
    )
    parser.add_argument(
        "files",
        nargs="*",
        type=Path,
        help="Explicit local files to upload.",
    )
    return parser.parse_args()


def get_active_subscription() -> dict[str, str]:
    try:
        proc = subprocess.run(
            ["az", "account", "show", "-o", "json"],
            check=True,
            capture_output=True,
            text=True,
        )
    except FileNotFoundError:
        print("ERROR: `az` CLI not found in PATH.", file=sys.stderr)
        sys.exit(2)
    except subprocess.CalledProcessError as exc:
        print("ERROR: failed to run `az account show`.", file=sys.stderr)
        if exc.stderr:
            print(exc.stderr.strip(), file=sys.stderr)
        sys.exit(2)

    try:
        data = json.loads(proc.stdout)
    except json.JSONDecodeError:
        print("ERROR: could not parse output from `az account show`.", file=sys.stderr)
        sys.exit(2)

    return {
        "name": str(data.get("name", "")),
        "id": str(data.get("id", "")),
    }


def verify_subscription(expected: str) -> None:
    active = get_active_subscription()
    if expected not in {active["name"], active["id"]}:
        print(
            "ERROR: active Azure subscription does not match.\n"
            f"  expected: {expected}\n"
            f"  active name: {active['name']}\n"
            f"  active id:   {active['id']}",
            file=sys.stderr,
        )
        sys.exit(2)


def resolve_input_files(args: argparse.Namespace) -> list[Path]:
    resolved: list[Path] = []
    errors: list[str] = []
    seen: set[Path] = set()

    # explicit files
    for file_path in args.files:
        path = file_path.expanduser()
        if not path.exists():
            errors.append(f"file not found: {path}")
            continue
        if not path.is_file():
            errors.append(f"not a file: {path}")
            continue
        norm = path.resolve()
        if norm not in seen:
            seen.add(norm)
            resolved.append(norm)

    # glob patterns expanded in Python
    for pattern in args.globs:
        expanded_pattern = str(Path(pattern).expanduser())
        matches = [Path(p).resolve() for p in glob(expanded_pattern, recursive=True)]

        if not matches:
            errors.append(f"glob matched no files: {pattern}")
            continue

        for match in matches:
            if not match.is_file():
                continue
            if match not in seen:
                seen.add(match)
                resolved.append(match)

    if errors:
        for error in errors:
            print(f"ERROR: {error}", file=sys.stderr)
        sys.exit(1)

    if not resolved:
        print(
            "ERROR: no files to upload. Provide explicit files and/or one or more --glob patterns.",
            file=sys.stderr,
        )
        sys.exit(1)

    return resolved


def list_existing_blobs(storage_account: str, container: str, prefix: str) -> set[str]:
    """Return set of blob names under prefix (used for --skip-existing)."""
    try:
        proc = subprocess.run(
            [
                "az", "storage", "blob", "list",
                "--account-name", storage_account,
                "--container-name", container,
                "--prefix", prefix,
                "--auth-mode", "login",
                "--output", "json",
                "--query", "[].name",
            ],
            check=True,
            capture_output=True,
            text=True,
        )
    except subprocess.CalledProcessError as exc:
        msg = "ERROR: failed to list existing blobs."
        if exc.stderr:
            msg += f"\n{exc.stderr.strip()}"
        print(msg, file=sys.stderr)
        sys.exit(1)
    return set(json.loads(proc.stdout))


def upload_blob(
    local_file: Path,
    storage_account: str,
    container: str,
    target_path: str,
) -> str:
    """Upload a single file to Azure Blob Storage using the az CLI."""
    blob_name = f"{target_path}/{local_file.name}"
    try:
        subprocess.run(
            [
                "az",
                "storage",
                "blob",
                "upload",
                "--account-name",
                storage_account,
                "--container-name",
                container,
                "--name",
                blob_name,
                "--file",
                str(local_file),
                "--auth-mode",
                "login",
                "--overwrite",
                "--output",
                "none",
            ],
            check=True,
            capture_output=True,
            text=True,
        )
    except subprocess.CalledProcessError as exc:
        msg = f"ERROR: failed to upload {local_file.name}."
        if exc.stderr:
            msg += f"\n{exc.stderr.strip()}"
        raise RuntimeError(msg) from exc
    return f"az://{container}/{blob_name}"


def main() -> None:
    args = parse_args()

    if args.workers < 1:
        print("ERROR: --workers must be >= 1", file=sys.stderr)
        sys.exit(2)

    verify_subscription(args.subscription)
    files = resolve_input_files(args)

    existing: set[str] = set()
    if args.skip_existing:
        print(f"Checking existing blobs under {args.storage_account}/{args.container}/{args.upload_dir} …")
        existing = list_existing_blobs(args.storage_account, args.container, args.upload_dir)
        skip_count = sum(1 for f in files if f"{args.upload_dir}/{f.name}" in existing)
        if skip_count:
            print(f"Skipping {skip_count} already-uploaded file(s).")
        files = [f for f in files if f"{args.upload_dir}/{f.name}" not in existing]
        if not files:
            print("All files already uploaded. Nothing to do.")
            return

    print(
        f"Uploading {len(files)} file(s) to "
        f"{args.storage_account}/{args.container}/{args.upload_dir} "
        f"({args.workers} worker{'s' if args.workers != 1 else ''})"
    )

    uploaded = 0
    lock = threading.Lock()

    def upload_one(local_file: Path) -> tuple[Path, str]:
        blob_path = upload_blob(
            local_file=local_file,
            storage_account=args.storage_account,
            container=args.container,
            target_path=args.upload_dir,
        )
        return local_file, blob_path

    try:
        with ThreadPoolExecutor(max_workers=args.workers) as pool:
            futures = {pool.submit(upload_one, f): f for f in files}
            for future in as_completed(futures):
                local_file, blob_path = future.result()
                with lock:
                    uploaded += 1
                    print(f"[{uploaded}/{len(files)}] ✓ {local_file.name} → {blob_path}")
    except RuntimeError as exc:
        print(str(exc), file=sys.stderr)
        sys.exit(1)

    print(f"\nDone: uploaded {uploaded} file(s).")


if __name__ == "__main__":
    main()
