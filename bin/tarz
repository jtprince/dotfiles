#!/usr/bin/env python3
import argparse
import shutil
import subprocess
from pathlib import Path

parser = argparse.ArgumentParser(description="Create a compressed tar archive from a directory.")
parser.add_argument("dirs", nargs="+", type=lambda p: Path(p.rstrip("/\\")), metavar="dir")
parser.add_argument("-d", "--delete", action="store_true", help="delete source dir after archiving")
parser.add_argument("-j", "--bzip2", action="store_true", help="use bzip2 compression (default: gzip)")
args = parser.parse_args()

ext = ".tar.bz2" if args.bzip2 else ".tgz"
flag = "cjf" if args.bzip2 else "czf"

for path in args.dirs:
    tarfile = Path(str(path) + ext)
    print(f"creating: {tarfile}")
    result = subprocess.run(["tar", flag, str(tarfile), str(path)])
    if result.returncode == 0 and args.delete:
        print(f"removing: {path}")
        shutil.rmtree(path)
