#!/usr/bin/env python3
import argparse
import secrets
import sys
from pathlib import Path

DICT = Path("/usr/share/dict/words")
SPECIAL = list("!@#$%^&*()")
WORD_LENGTH = 5


def load_words() -> list[str]:
    if not DICT.exists():
        sys.exit(f"error: {DICT} not found — install a words package (brew install words)")
    return [w.strip().replace("'", "") for w in DICT.read_text().splitlines() if w.strip()]


def random_word(words: list[str]) -> str:
    word = secrets.choice(words)[:WORD_LENGTH]
    return "".join(c.upper() if secrets.randbelow(2) else c.lower() for c in word)


def generate(words: list[str]) -> str:
    return (
        secrets.token_urlsafe(6)
        + secrets.choice(SPECIAL)
        + random_word(words)
        + secrets.choice(SPECIAL)
        + secrets.token_urlsafe(6)
        + random_word(words)
    )


parser = argparse.ArgumentParser(description="Generate a secure random password.")
parser.add_argument("length", nargs="?", type=int, help="truncate to this length")
args = parser.parse_args()

words = load_words()
passwd = generate(words)
print(passwd if args.length is None else passwd[: args.length])
