#!/usr/bin/env python3

import argparse
import shlex
import subprocess

parser = argparse.ArgumentParser(epilog="(hint: use :AnsiEsc to view in vim)")
parser.add_argument("files", nargs=2, metavar=("file1", "file2"))
parser.add_argument(
    "-n",
    "--notation",
    action="store_true",
    help="preserve diff symbols (--word-diff=plain)",
)
parser.add_argument(
    "-c", "--cmd", action="store_true", help="just print the command being used"
)

args = parser.parse_args()

cmd = (
    ["git", "diff", "--no-index", "--color-words"]
    + (["--word-diff=plain"] if args.notation else [])
    + args.files
)

if args.cmd:
    print(shlex.join(cmd))
else:
    subprocess.run(cmd)
