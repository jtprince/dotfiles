#!/usr/bin/env python3
import argparse
import platform
import shutil
import subprocess
from time import sleep, time

DEFAULT_MINUTES = 15
WATCHFACE = "********************* {} *********************"

parser = argparse.ArgumentParser(description="Countdown timer.")
parser.add_argument("minutes", nargs="?", type=float, default=DEFAULT_MINUTES, help="minutes to time (default: 15)")
parser.add_argument("--no-beep", action="store_true", help="skip the beep at the end")
args = parser.parse_args()

wanted_seconds = args.minutes * 60
start = time()


def beep() -> None:
    if platform.system() == "Darwin":
        subprocess.run(["afplay", "/System/Library/Sounds/Glass.aiff"])
    elif shutil.which("play"):
        subprocess.run(["play", "-q", "-n", "synth", "0.025", "sin", "650"])
    else:
        print("\a", end="", flush=True)


def print_time(leftover: float) -> None:
    mins, secs = divmod(leftover, 60)
    print(f"\r{WATCHFACE.format(f'{round(mins):02d}:{secs:04.1f}')}", end="", flush=True)


try:
    while True:
        leftover = wanted_seconds - (time() - start)
        if leftover <= 0:
            break
        print_time(leftover)
        sleep(0.5)

    print_time(0)
    print("\ndone")
    if not args.no_beep:
        beep()

except KeyboardInterrupt:
    print_time(wanted_seconds - (time() - start))
    print()
