#!/usr/bin/env python3
import argparse
import gzip
from pathlib import Path

parser = argparse.ArgumentParser(
    usage="gunzip-many [-k] <file>.gz ...",
    description="Decompress one or more .gz files.",
)
parser.add_argument("files", nargs="+", metavar="file.gz")
parser.add_argument("-k", "--keep", action="store_true", help="keep the originals")
args = parser.parse_args()

for path in map(Path, args.files):
    path.with_suffix("").write_bytes(gzip.decompress(path.read_bytes()))
    if not args.keep:
        path.unlink()
