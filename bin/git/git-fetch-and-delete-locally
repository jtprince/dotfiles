#!/usr/bin/env python3

import argparse
import re
import subprocess
import sys

DEFAULT_MAIN_BRANCH = subprocess.check_output(["git-main-branch"], text=True).strip()

parser = argparse.ArgumentParser()
parser.add_argument("-f", "--force", action="store_true", help="force deletion of branches not fully merged")
parser.add_argument("-b", "--main-branch", default=DEFAULT_MAIN_BRANCH, help=f"main branch to use, default: {DEFAULT_MAIN_BRANCH}")
args = parser.parse_args()


def run(command, print_cmd=False, print_response=False, check=False):
    if print_cmd:
        print(f"running: {command}")
    result = subprocess.run(command, shell=True, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
    response = result.stdout.rstrip()
    if check and result.returncode != 0:
        print(f"error: '{command}' failed:\n{response}", file=sys.stderr)
        sys.exit(result.returncode)
    if print_response:
        print(response)
    return response


def gone_branches():
    """Return local branches whose upstream has been deleted (shows ': gone]' in git branch -vv)."""
    output = run("git branch -vv")
    branches = []
    for line in output.split("\n"):
        line = re.sub(r"^\s*\*\s*", "", line).strip()
        if ": gone]" in line:
            branches.append(line.split()[0])
    return branches


run("git fetch -p")
run(f"git checkout {args.main_branch}", check=True)
run("git pull")

to_delete = gone_branches()

if not to_delete:
    print("<< No local branches without a remote. >>")

for branch in to_delete:
    delete_opt = "-D" if args.force else "-d"
    response = run(f"git branch {delete_opt} {branch}", print_cmd=True, print_response=True)

    if "not fully merged" in response:
        remote = f"origin/{args.main_branch}"
        diff = run(f"git diff {branch} {remote}", print_cmd=True, print_response=True)
        if not diff:
            print(f"No difference between {branch} and {remote}, force deleting")
            run(f"git branch -D {branch}", print_cmd=True, print_response=True)
