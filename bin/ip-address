#!/usr/bin/env python

import sys
import argparse
import subprocess
import shutil

import platform

containing_package = {
    "Darwin": {"ip": "iproute2mac", "dig": "bind"},
    "Linux": {"ip": "iproute2", "dig": "bind"},
}
install_pkg = {"Linux": "yay -S", "Darwin": "brew install"}

platform = platform.system()
install_cmd = install_pkg[platform]

ip_containing_pkg = containing_package[platform]["ip"]
dig_containing_pkg = containing_package[platform]["dig"]

ip_install = f"{install_cmd} {ip_containing_pkg}"
dig_install = f"{install_cmd} {dig_containing_pkg}"

parser = argparse.ArgumentParser(description="get local/world ip addresses")
parser.add_argument("-l", "--local", action="store_true", help="just local")
parser.add_argument("-w", "-g", "--world", action="store_true", help="just wan")
args = parser.parse_args()


def require_executable(cmd: str, install_hint: str | None = None) -> str:
    path = shutil.which(cmd)
    if path is None:
        msg = [f"Error: required executable '{cmd}' was not found in PATH."]
        if install_hint:
            msg.append(f"Install it with: {install_hint}")
        else:
            msg.append("Ensure it is installed and available on your PATH.")
        sys.exit("\n".join(msg))
    return path


def run(cmd):
    return subprocess.check_output(cmd, shell=True, text=True).strip()


if not args.world:
    require_executable("ip", ip_install)
    lan = run("ip -json route get 8.8.8.8 | jq -r '.[].prefsrc'")
    print("local:", lan)

if not args.local:
    require_executable("dig", dig_install)
    cmd = """
        dig TXT +short o-o.myaddr.l.google.com @ns1.google.com | sed 's/"//g'
    """
    wan = run(cmd)
    print("world:", wan)
