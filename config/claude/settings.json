{
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cavemem hook run session-start --ide claude-code"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cavemem hook run user-prompt-submit --ide claude-code"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cavemem hook run post-tool-use --ide claude-code"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cavemem hook run stop --ide claude-code"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cavemem hook run session-end --ide claude-code"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "cavekit-marketplace": {
      "source": {
        "source": "github",
        "repo": "juliusbrussee/cavekit"
      }
    }
  },
  "promptSuggestionEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "verbose": true,
  "remoteControlAtStartup": true,
  "skipAutoPermissionPrompt": true,
  "mcpServers": {
    "cavemem": {
      "command": "cavemem",
      "args": [
        "mcp"
      ]
    }
  },
  "model": "sonnet"
}
