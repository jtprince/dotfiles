{
  "permissions": {
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh release create:*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/no-blanket-git-add.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "serena-hooks remind --client=claude-code"
          }
        ]
      },
      {
        "matcher": "mcp__serena__*",
        "hooks": [
          {
            "type": "command",
            "command": "serena-hooks auto-approve --client=claude-code"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cavemem hook run session-start --ide claude-code"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "serena-hooks activate --client=claude-code"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cavemem hook run user-prompt-submit --ide claude-code"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cavemem hook run post-tool-use --ide claude-code"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cavemem hook run stop --ide claude-code"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cavemem hook run session-end --ide claude-code"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "serena-hooks cleanup --client=claude-code"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "frontend-design@claude-plugins-official": true,
    "enveda-databricks@enveda-ai-plugin-marketplace": true,
    "enveda-python@enveda-ai-plugin-marketplace": true,
    "enveda-prefect@enveda-ai-plugin-marketplace": true,
    "enveda-documentation@enveda-ai-plugin-marketplace": true,
    "enveda-kr-posts@enveda-ai-plugin-marketplace": true,
    "enveda-reusable-workflows@enveda-ai-plugin-marketplace": true,
    "code-review@claude-plugins-official": true,
    "enveda-ui-ux@enveda-ai-plugin-marketplace": true,
    "enveda-vibe-coding@enveda-ai-plugin-marketplace": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "cavekit-marketplace": {
      "source": {
        "source": "github",
        "repo": "juliusbrussee/cavekit"
      }
    }
  },
  "promptSuggestionEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "verbose": true,
  "remoteControlAtStartup": true,
  "skipAutoPermissionPrompt": true,
  "mcpServers": {
    "cavemem": {
      "command": "cavemem",
      "args": [
        "mcp"
      ]
    }
  }
}
