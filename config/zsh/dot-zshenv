# .zshenv — sourced for ALL zsh shells (login, non-login, interactive, non-interactive)
# Put PATH and environment that must always be available here.

# macOS-specific
if [[ "$(uname)" == "Darwin" ]]; then
	export PATH="$PATH:/Applications/Visual Studio Code.app/Contents/Resources/app/bin"
	if [[ -x /opt/homebrew/bin/brew ]]; then
		eval "$(/opt/homebrew/bin/brew shellenv)"
	fi
fi

# See `cheat uv` robust user-wide setup for details
export PYTHON_GLOBAL_VENV="$HOME/.local/uv-global"
export PATH="$PYTHON_GLOBAL_VENV/bin:$PATH"

BINPATH="$HOME/bin"
export PATH="$BINPATH/docker:$PATH"
export PATH="$BINPATH/git:$PATH"
export PATH="$BINPATH/markdown:$PATH"
export PATH="$BINPATH/media:$PATH"
export PATH="$BINPATH/python:$PATH"
export PATH="$BINPATH/work:$PATH"
export PATH="$BINPATH:$PATH"
export PATH="$HOME/.local/bin:$PATH"
export PATH="$BINPATH/aliases:$PATH"

# Load sheldon plugins (must be after PATH is set so sheldon is found)
eval "$(sheldon source)"
