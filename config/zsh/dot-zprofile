# .zprofile — sourced for login shells, AFTER /etc/zprofile
# PATH setup lives here so it runs after macOS path_helper.
# On Linux /etc/zprofile is absent or benign, so this is correct everywhere.
# Child processes (non-login shells, scripts) inherit PATH from the login shell.

if [[ "$(uname)" == "Darwin" ]]; then
	export PATH="/opt/homebrew/opt/perl/bin:$PATH"
	export PATH="$PATH:/Applications/Visual Studio Code.app/Contents/Resources/app/bin"
	if [[ -x /opt/homebrew/bin/brew ]]; then
		# Cache `brew shellenv` — saves a brew subprocess on every login shell.
		_brew_cache="$HOME/.cache/zsh-init/brew-shellenv.zsh"
		if [[ ! -s $_brew_cache || /opt/homebrew/bin/brew -nt $_brew_cache ]]; then
			mkdir -p ${_brew_cache:h}
			/opt/homebrew/bin/brew shellenv > $_brew_cache
		fi
		source $_brew_cache
		unset _brew_cache
	fi
fi

export PATH="$PYTHON_GLOBAL_VENV/bin:$PATH"

BINPATH="$HOME/bin"
export PATH="$BINPATH/data:$PATH"
export PATH="$BINPATH/docker:$PATH"
export PATH="$BINPATH/git:$PATH"
export PATH="$BINPATH/markdown:$PATH"
export PATH="$BINPATH/media:$PATH"
export PATH="$BINPATH/python:$PATH"
export PATH="$BINPATH/work:$PATH"
export PATH="$BINPATH:$PATH"
export PATH="$HOME/.local/bin:$PATH"
export PATH="$BINPATH/aliases:$PATH"
