# Some programs do not understand the XDG spec and put things in config when
# they should go in .cache.  Ignore the junk.

.tags
.vim
.python-version
__pycache__
.DS_Store

/config/zsh/.zcompdump*

/config/linux/pulse/*.tdb
/config/linux/pulse/cookie
/config/linux/pulse/*-default-sink
/config/linux/pulse/*-default-source

/config/git/gitk

/config/ipython/profile_default/history.sqlite
/config/ipython/profile_autoreload/history.sqlite

/config/mpv/watch_later

lazy-lock.json

/config/kitty/kitty.conf
